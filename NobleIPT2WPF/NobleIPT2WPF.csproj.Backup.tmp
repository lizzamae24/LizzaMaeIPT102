<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackLocationReference Include="Microsoft.Data.SqlClient" Version="7.0.0" />
    <PackLocationReference Include="Microsoft.Extensions.Configuration" Version="11.0.0-preview.2.26159.112" />
    <PackLocationReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="11.0.0-preview.2.26159.112" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NobleIPT2Domain\NobleIPT2Domain.csproj" />
    <ProjectReference Include="..\NobleIPT2Framework\NobleIPT2Framework.csproj" />
  </ItemGroup>

</Project>
